# =============================================================================
# EasyTrip Mobile — Environment Variables
# =============================================================================
# These are Expo public env vars (prefixed EXPO_PUBLIC_*).
# Safe to include in JS bundle — DO NOT put secrets here.
# Secrets live in server/.env only.
#
# Copy this file:
#   cp .env.example .env
#   (then fill in values)
# =============================================================================

# ── API ────────────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# ── Supabase (public/anon key only — safe in client) ──────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── Analytics ──────────────────────────────────────────────────────────────────
# PostHog project API key (public key, safe in client)
EXPO_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── Error Tracking ─────────────────────────────────────────────────────────────
# Sentry DSN (public, safe in client)
EXPO_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ── Maps ───────────────────────────────────────────────────────────────────────
# Google Maps API key — RESTRICT to your iOS bundle ID + Android package in Google Cloud Console
# ios: com.easytrip.app | android: com.easytrip.app
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...your-maps-key...

# ── Feature Flags ──────────────────────────────────────────────────────────────
# Set to 'true' to enable social intelligence features (v1.5+)
EXPO_PUBLIC_SOCIAL_INTEL_ENABLED=false

# Set to 'true' to show debug UI (never enable in production builds)
EXPO_PUBLIC_DEBUG_UI=false

# ── Environment ────────────────────────────────────────────────────────────────
# development | staging | production
EXPO_PUBLIC_ENVIRONMENT=development

# ── Stripe (publishable key — safe in client) ──────────────────────────────────
# Only used for web checkout redirect (iOS uses Apple IAP, Android uses Google IAP)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...your-stripe-publishable-key...
