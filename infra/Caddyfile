# EasyTrip Reverse Proxy
# Production: Caddy runs on a small EC2 or ECS container in front of the ALB
# Staging: Used for local prod simulation
#
# Caddy auto-provisions TLS via Let's Encrypt when a real domain is used.
# For local dev, uses self-signed certs automatically.

# Global options
{
    # Email for Let's Encrypt notifications
    email devops@easytrip.app

    # Enable HTTP/3 (QUIC)
    servers {
        protocols h1 h2 h3
    }

    # Logging
    log {
        output stderr
        format json
        level INFO
    }
}

# API — primary endpoint
api.easytrip.app {
    # TLS (auto via Let's Encrypt)
    tls {
        protocols tls1.2 tls1.3
        ciphers TLS_AES_128_GCM_SHA256 TLS_AES_256_GCM_SHA384 TLS_CHACHA20_POLY1305_SHA256
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # Rate limiting (basic — real rate limiting is in app + Redis)
    # 200 requests/minute per IP
    rate_limit {
        zone static_zone {
            match {
                method GET HEAD
            }
            key {remote_host}
            events 500
            window 1m
        }
        zone dynamic_zone {
            match {
                method POST PUT PATCH DELETE
            }
            key {remote_host}
            events 200
            window 1m
        }
    }

    # WebSocket support for Socket.io
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websocket api:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        transport http {
            dial_timeout 10s
            response_header_timeout 60s
            read_timeout 0   # WebSocket: no read timeout
        }
    }

    # HTTP/REST
    reverse_proxy api:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        
        # Health check
        health_uri /health
        health_interval 30s
        health_timeout 5s
        health_status 200

        transport http {
            dial_timeout 10s
            response_header_timeout 30s
            read_timeout 60s
            write_timeout 60s
        }
    }

    # Logging
    log {
        output file /var/log/caddy/api.log {
            roll_size 100mb
            roll_keep 10
        }
        format json
    }
}

# Staging API
api-staging.easytrip.app {
    tls {
        protocols tls1.2 tls1.3
    }

    header {
        Strict-Transport-Security "max-age=3600"
        X-Environment "staging"
        -Server
    }

    reverse_proxy api:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# Redirect www to apex (if web app is added later)
www.easytrip.app {
    redir https://easytrip.app{uri} permanent
}
