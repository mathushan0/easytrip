# =============================================================================
# EasyTrip Server — Environment Variables
# =============================================================================
# ALL secrets live here. Never commit a filled-in .env file.
# In production, these are injected from AWS Secrets Manager.
#
# Copy this file:
#   cp server/.env.example server/.env
#   (then fill in all values)
# =============================================================================

# ── Database ───────────────────────────────────────────────────────────────────
# Local dev: postgresql://postgres:password@localhost:5432/easytrip
# Staging/Prod: use RDS Proxy endpoint from Terraform outputs
DATABASE_URL=postgresql://postgres:password@localhost:5432/easytrip

# ── Redis ──────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Staging/Prod: use ElastiCache endpoint with auth token
# redis://:AUTH_TOKEN@your-cluster.cache.amazonaws.com:6379
REDIS_URL=redis://localhost:6379

# ── Auth (Supabase) ────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# Anon key (safe to expose publicly, but we also need it server-side)
SUPABASE_ANON_KEY=eyJ...
# Service role key — NEVER expose this. Server only. Full database access.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── AI ─────────────────────────────────────────────────────────────────────────
# Primary: Claude 3.5 Sonnet — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Fallback + social extraction: GPT-4o — https://platform.openai.com
OPENAI_API_KEY=sk-proj-...

# ── Google APIs ────────────────────────────────────────────────────────────────
# Restrict each key to specific APIs in Google Cloud Console

# Places API (New) + Maps JavaScript API
# Restrict: Server IP whitelist (your ECS task IPs or VPC NAT IP)
GOOGLE_PLACES_API_KEY=AIzaSy...

# Directions API
GOOGLE_MAPS_API_KEY=AIzaSy...

# Cloud Translation API
GOOGLE_TRANSLATE_API_KEY=AIzaSy...

# Cloud Vision API (for OCR)
GOOGLE_CLOUD_VISION_API_KEY=AIzaSy...

# Cloud Text-to-Speech API (for phrase audio)
GOOGLE_CLOUD_TTS_API_KEY=AIzaSy...

# ── Payments (Stripe) ──────────────────────────────────────────────────────────
# Use test keys (sk_test_...) for dev/staging, live keys (sk_live_...) for prod
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — get from Stripe Dashboard after creating products
STRIPE_PRICE_VOYAGER_LIFETIME=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx

# ── Social Intelligence ────────────────────────────────────────────────────────
# Twitter/X API v2 Basic ($100/mo) — https://developer.twitter.com
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAA...

# YouTube Data API v3 — https://console.cloud.google.com (free quota)
YOUTUBE_API_KEY=AIzaSy...

# Reddit API — https://www.reddit.com/prefs/apps (free)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Data Services ──────────────────────────────────────────────────────────────
# Open Exchange Rates — https://openexchangerates.org ($10/mo)
OPEN_EXCHANGE_RATES_APP_ID=your_app_id

# OpenWeatherMap — https://openweathermap.org/api (free tier sufficient)
OPENWEATHERMAP_API_KEY=your_api_key

# ── Error Tracking ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ── AWS ────────────────────────────────────────────────────────────────────────
# In production (ECS), these are provided by the task IAM role — no static keys needed.
# For local dev, use your personal AWS credentials.
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

S3_BUCKET_NAME=easytrip-media-dev
CLOUDFRONT_DOMAIN=media-dev.easytrip.app

# ── Translation Fallback ───────────────────────────────────────────────────────
# LibreTranslate self-hosted instance (started via docker compose --profile local)
LIBRETRANSLATE_URL=http://localhost:5000

# ── App Config ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# CORS origin — for local dev, allow all. In staging/prod, set to specific domain.
CORS_ORIGIN=http://localhost:8081

# AI prompt template version (must match prompt_templates table)
PROMPT_VERSION=v1.0

# Rate limiting — requests per window (production defaults in code)
# These override the defaults if set
RATE_LIMIT_GLOBAL_PER_HOUR=1000
RATE_LIMIT_AI_GEN_PER_HOUR=10
